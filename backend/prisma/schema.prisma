// Prisma schema untuk migrasi backend NestJS.
// Hanya menyisakan tabel domain aplikasi (users & internship_applications).
// Tabel infrastruktur Laravel (sessions, cache, jobs, dll) sengaja dihapus
// karena auth kini memakai JWT dan antrian memakai BullMQ + Redis.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // NestJS berjalan sebagai CommonJS, paksa format modul agar import konsisten.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "mysql"
  // URL koneksi tidak ditaruh di sini (tidak didukung Prisma 7). Untuk perintah
  // CLI (migrate/db pull) URL dibaca dari prisma.config.ts, sedangkan runtime
  // memakai driver adapter PrismaMariaDb (lihat src/prisma/prisma.service.ts).
}

// Pengguna aplikasi. Nama field dibiarkan snake_case mengikuti tabel Laravel
// agar shape JSON respons tetap identik dengan backend lama.
model User {
  id                        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name                      String    @db.VarChar(255)
  username                  String    @unique(map: "users_username_unique") @db.VarChar(255)
  email                     String    @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at         DateTime? @db.Timestamp(0)
  password                  String    @db.VarChar(255)
  two_factor_secret         String?   @db.Text
  two_factor_recovery_codes String?   @db.Text
  two_factor_confirmed_at   DateTime? @db.Timestamp(0)
  remember_token            String?   @db.VarChar(100)
  // Hash (SHA-256 hex) dari refresh token yang sedang aktif. Diisi saat login,
  // dirotasi saat refresh, dan dikosongkan saat logout agar token bisa di-revoke.
  refresh_token_hash        String?   @db.VarChar(64)
  created_at                DateTime? @db.Timestamp(0)
  updated_at                DateTime? @db.Timestamp(0)

  @@map("users")
}

// Lamaran magang yang dikirim pelamar. resume_text diisi hasil ekstraksi PDF.
model InternshipApplication {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  first_name  String    @db.VarChar(100)
  last_name   String    @db.VarChar(100)
  email       String    @db.VarChar(255)
  phone       String    @db.VarChar(20)
  about       String    @db.Text
  resume_path String    @db.VarChar(255)
  resume_text String?   @db.LongText
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)

  @@map("internship_applications")
}
